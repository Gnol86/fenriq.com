# Database URL (use the same address in development, only use pooled in production if you use neon.tech)
DATABASE_URL="xxx"
DATABASE_URL_UNPOOLED="xxx"

## AWS S3 Configuration
AWS_S3_PROTOCOL="https"
AWS_S3_HOSTNAME="localhosr"
AWS_S3_REGION="eu-east-1"
AWS_S3_BUCKET="bucket"
AWS_S3_ACCESS_KEY_ID="xxx"
AWS_S3_SECRET_ACCESS_KEY="xxx"

## BetterAuth
BETTER_AUTH_SECRET="xxx"
BETTER_AUTH_BASE_URL="http://localhost:3000"
BETTER_AUTH_TELEMETRY=0

## Next.js
NEXT_TELEMETRY_DISABLED=1
CHECKLIST_PHOTO_CLEANUP_SECRET="xxx"

## * Resend
RESEND_API_KEY="xxx"
RESEND_AUDIENCE_ID="xxx"
EMAIL_FROM="noreply@"
NEXT_PUBLIC_EMAIL_CONTACT="contact@"

## * STRIPE
STRIPE_SECRET_KEY="xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="xxx"
STRIPE_WEBHOOK_SECRET="xxx"
STRIPE_MONTHLY_PLAN_ID="xxx"
# STRIPE_PACK_ID="xxx" # If plan mode is selected
